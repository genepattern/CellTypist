p7_default_value=best match
p7_description=Prediction mode for cell type assignment. 'best match' assigns each cell exactly one label (the highest-probability cell type), regardless of confidence. 'prob match' assigns each cell one or more labels (pipe-separated) for every cell type whose probability exceeds the probability.threshold; cells with no type above the threshold are labeled 'Unassigned'. Use 'prob match' for transitional or ambiguous cell states.
p7_name=prediction.mode
p7_numValues=1..1
p7_optional=on
p7_prefix_when_specified=--prediction.mode 
p7_type=java.lang.String
p7_value=best match\=best match - Single label (highest probability);prob match\=prob match - Multi-label (all types above threshold)
p8_TYPE=Floating Point
p8_default_value=0.5
p8_description=Probability cutoff used in 'prob match' prediction mode. Cell types with a probability score below this threshold are excluded from the multi-label assignment. Cells with no cell type above the threshold are labeled 'Unassigned'. Value must be between 0.0 and 1.0. This parameter has no effect when prediction.mode is set to 'best match'.
p8_name=probability.threshold
p8_numValues=1..1
p8_optional=on
p8_prefix_when_specified=--probability.threshold 
p8_range=0.0..1.0
p8_type=java.lang.Float
p9_default_value=false
p9_description=Whether to enable majority-vote post-processing. When true, Leiden over-clustering (resolution=5) is applied to the query data neighborhood graph, and each resulting sub-cluster is assigned the plurality cell type among its members. This smooths noisy single-cell predictions by leveraging transcriptional similarity across neighboring cells. Sub-clusters where the plurality cell type comprises less than min.proportion of the cluster are labeled 'Heterogeneous'. Requires that the input AnnData has a pre-computed neighborhood graph, or neighbors will be computed automatically.
p9_name=majority.voting
p9_numValues=1..1
p9_optional=on
p9_prefix_when_specified=--majority.voting 
p9_type=java.lang.String
p9_value=false\=false - Disable majority voting (per-cell predictions only);true\=true - Enable majority voting (neighborhood-smoothed predictions)
p10_TYPE=Floating Point
p10_default_value=0
p10_description=Minimum fraction of the dominant cell type within a sub-cluster for majority voting. Only used when majority.voting is true. Sub-clusters where the plurality cell type comprises less than this fraction of cells are labeled 'Heterogeneous' to flag ambiguous or mixed clusters. Value must be between 0.0 and 1.0. Default is 0 (no minimum required).
p10_name=min.proportion
p10_numValues=1..1
p10_optional=on
p10_prefix_when_specified=--min.proportion 
p10_range=0.0..1.0
p10_type=java.lang.Float
p11_default_value=celltypist_output
p11_description=Prefix string for all output file names. Output files will be named: {prefix}_predicted_labels.csv, {prefix}_probability_matrix.csv, {prefix}_decision_matrix.csv, and {prefix}_annotated.h5ad. If plot.results is true, UMAP and dot plot figures will also use this prefix.
p11_name=output.prefix
p11_numValues=1..1
p11_optional=on
p11_prefix_when_specified=--output.prefix 
p11_type=java.lang.String
p12_default_value=false
p12_description=Whether to generate visualization plots. When true, CellTypist produces UMAP plots overlaid with predicted cell type labels and confidence scores, as well as dot plots showing probability distributions across cell types. Plots are saved as both PDF and PNG files. Requires that the input AnnData contains UMAP coordinates; if absent, UMAP will be computed automatically using scanpy.
p12_name=plot.results
p12_numValues=1..1
p12_optional=on
p12_prefix_when_specified=--plot.results 
p12_type=java.lang.String
p12_value=false\=false - Do not generate plots;true\=true - Generate UMAP and dot plots