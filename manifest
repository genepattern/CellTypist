# GenePattern Module Manifest

LSID=urn:lsid:broad.mit.edu:cancer.software.genepattern.module.generated:40153:1
name=CellTypist
version=1.0.0
author=GenePattern Team
description=CellTypist is an automated cell type annotation tool for single-cell RNA-sequencing (scRNA-seq) datasets. Using logistic regression classifiers optimized by stochastic gradient descent (SGD), CellTypist rapidly assigns cell type labels to query cells using either built-in curated models (derived from the Human Cell Atlas) or user-provided custom models. It supports best-match (single-label) and prob-match (multi-label) prediction modes, optional majority-voting post-processing via Leiden over-clustering, and produces predicted label tables, probability matrices, decision matrices, annotated AnnData output, and optional UMAP visualizations.
categories=Single-Cell Analysis;Cell Type Annotation;RNA-seq
commandLine=python <libdir>wrapper.py <input.file> <gene.file> <cell.file> <builtin.model> <custom.model.file> <transpose.input> <prediction.mode> <probability.threshold> <majority.voting> <min.proportion> <output.prefix> <plot.results>
cpuType=any
os=any
language=Python
taskType=Single-Cell Analysis
documentationUrl=https://github.com/Teichlab/celltypist
quality=production
privacy=public
job.cpuCount=4
job.memory=8Gb
job.docker.image=genepattern/celltypist\:1
src.repo=https://github.com/Teichlab/celltypist

